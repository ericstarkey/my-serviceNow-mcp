# ---- Required: ServiceNow ----
SERVICENOW_INSTANCE_URL=https://dev12345.service-now.com
AUTH_TYPE=api_key
SERVICENOW_API_KEY=your-servicenow-api-key-here

# ---- Transport ----
# Options: stdio (default) | http
MCP_TRANSPORT=stdio

# ---- HTTP mode only ----
MCP_PORT=8080
MCP_SERVER_API_KEY=your-inbound-mcp-key-here

# ---- Optional ----
SERVICENOW_TIMEOUT=30000
LOG_LEVEL=info
# NODE_ENV=production
