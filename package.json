{
  "name": "my-servicenow-mcp",
  "version": "0.1.0",
  "description": "ServiceNow MCP server — wraps the ServiceNow REST API as MCP tools and resources",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:http": "cross-env MCP_TRANSPORT=http tsx watch src/server/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:coverage": "vitest run --coverage tests/unit",
    "test:integration": "cross-env INTEGRATION_TESTS=true vitest run tests/integration",
    "test:integration:http": "cross-env INTEGRATION_TESTS_HTTP=true vitest run tests/integration/server",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0",
    "axios": "^1.7",
    "dotenv": "^16.4",
    "express": "^4.19",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@eslint/js": "^9.0",
    "@types/express": "^4.17",
    "@types/node": "^20.0",
    "@typescript-eslint/eslint-plugin": "^8.0",
    "@typescript-eslint/parser": "^8.0",
    "@vitest/coverage-v8": "^1.6",
    "cross-env": "^7.0",
    "eslint": "^9.0",
    "prettier": "^3.0",
    "tsx": "^4.0",
    "typescript": "^5.4",
    "vitest": "^1.6"
  }
}
